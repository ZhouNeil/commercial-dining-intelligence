          "w_rating": {
            "type": "number",
            "maximum": 2.0,
            "minimum": 0.0,
            "title": "W Rating",
            "default": 1.05
          },
          "w_price": {
            "type": "number",
            "maximum": 2.0,
            "minimum": 0.0,
            "title": "W Price",
            "default": 0.15
          },
          "w_distance": {
            "type": "number",
            "maximum": 2.0,
            "minimum": 0.0,
            "title": "W Distance",
            "default": 0.2
          },
          "w_popularity": {
            "type": "number",
            "maximum": 2.0,
            "minimum": 0.0,
            "title": "W Popularity",
            "default": 0.1
          },
          "liked_business_ids": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Liked Business Ids"
          },
          "disliked_business_ids": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Disliked Business Ids"
          },
          "rl_enabled": {
