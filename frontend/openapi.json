            "description": "Client action events since the last search (RL feedback)"
          }
        },
        "type": "object",
        "required": [
          "state"
        ],
        "title": "SearchRequest",
        "description": "Search request body aligned with the `/search` page (Step1–2 and sidebar weights)."
      },
