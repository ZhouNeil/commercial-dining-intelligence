    "/api/v1/merchant/cities": {
      "get": {
        "summary": "Merchant Cities",
        "operationId": "merchant_cities_api_v1_merchant_cities_get",
        "parameters": [
          {
            "name": "min_rows",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 5000,
              "minimum": 1,
              "default": 50,
              "title": "Min Rows"
            }
          }
