        "required": [
          "reference_row_count",
          "grid_size",
          "min_lat",
          "max_lat",
          "min_lon",
          "max_lon"
        ],
        "title": "MerchantHeatmapResponse"
      },
      "MerchantPredictRequest": {
        "properties": {
          "city": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "City",
            "description": "Filter reference businesses; if empty, use the first N rows of the table"
          },
          "state": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "State",
            "description": "Optional USPS state to disambiguate duplicate city names (must match train_spatial.state)."
          },
          "lat": {
            "type": "number",
            "title": "Lat"
          },
          "lon": {
            "type": "number",
            "title": "Lon"
          },
          "category_keys": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Category Keys",
            "description": "Explicit train_spatial cat_* columns. Optional if category_query is set."
          },
          "category_query": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Category Query",
            "description": "Plain text (e.g. 'fast food, coffee', 'burger'); server maps to cat_* in the current slice."
          },
          "max_rows_if_no_city": {
            "type": "integer",
            "maximum": 50000.0,
            "minimum": 100.0,
            "title": "Max Rows If No City",
            "default": 2000
