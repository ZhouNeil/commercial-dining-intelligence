            ],
            "title": "City Filter"
          },
          "reference_count": {
            "type": "integer",
            "title": "Reference Count"
          },
          "geo_count": {
            "type": "integer",
            "title": "Geo Count"
          },
          "min_lon": {
            "type": "number",
            "title": "Min Lon"
          },
          "min_lat": {
            "type": "number",
            "title": "Min Lat"
          },
          "max_lon": {
            "type": "number",
            "title": "Max Lon"
          },
          "max_lat": {
            "type": "number",
            "title": "Max Lat"
          },
          "center_lon": {
            "type": "number",
            "title": "Center Lon"
          },
          "center_lat": {
            "type": "number",
            "title": "Center Lat"
          },
          "hull_geojson": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
