          },
          "repo_root": {
            "type": "string",
            "title": "Repo Root"
          },
          "spatial_csv": {
            "type": "boolean",
            "title": "Spatial Csv"
          },
          "survival_pkl": {
            "type": "boolean",
            "title": "Survival Pkl"
          },
          "rating_pkl": {
            "type": "boolean",
