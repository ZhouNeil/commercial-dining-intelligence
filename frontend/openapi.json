            "title": "Hull Geojson"
          },
          "sample_points_geojson": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Sample Points Geojson"
          },
          "valid_hull": {
            "type": "boolean",
            "title": "Valid Hull"
          }
        },
        "type": "object",
        "required": [
          "reference_count",
          "geo_count",
          "min_lon",
          "min_lat",
          "max_lon",
          "max_lat",
          "center_lon",
          "center_lat",
          "valid_hull"
        ],
        "title": "MerchantCoverageResponse",
        "description": "Map overlay: bbox, centroid, convex hull of reference rows, sampled training points."
      },
      "MerchantHeatmapRequest": {
        "properties": {
          "city": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "City"
          },
          "state": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "State",
            "description": "Optional USPS state (must match train_spatial.state when used)."
          },
          "category_keys": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Category Keys",
            "description": "Explicit cat_* columns; optional if category_query is set."
          },
          "category_query": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Category Query",
            "description": "Plain text resolved to cat_* in the current slice (same as /merchant/predict)."
          },
          "max_rows_if_no_city": {
            "type": "integer",
            "maximum": 50000.0,
            "minimum": 100.0,
            "title": "Max Rows If No City",
            "default": 2000
          },
          "price_level": {
            "anyOf": [
              {
                "type": "integer",
                "maximum": 4.0,
                "minimum": 1.0
              },
              {
                "type": "null"
              }
            ],
            "title": "Price Level",
            "description": "Yelp-style tier vs local mean within 1 km."
          },
          "price_per_person": {
            "anyOf": [
              {
                "type": "number",
                "minimum": 0.0
              },
              {
                "type": "null"
              }
            ],
            "title": "Price Per Person"
          },
          "grid_size": {
            "type": "integer",
            "maximum": 16.0,
            "minimum": 4.0,
            "title": "Grid Size",
            "description": "Number of rows/columns over min/max lat/lon of the reference slice (max 256 cells).",
            "default": 12
          }
        },
        "type": "object",
        "title": "MerchantHeatmapRequest",
        "description": "Same filters as merchant predict, without a pin — scores a regular grid over the slice bbox."
      },
      "MerchantHeatmapResponse": {
        "properties": {
          "city_filter": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "City Filter"
          },
          "reference_row_count": {
            "type": "integer",
            "title": "Reference Row Count"
          },
          "grid_size": {
            "type": "integer",
            "title": "Grid Size"
          },
          "min_lat": {
            "type": "number",
            "title": "Min Lat"
          },
          "max_lat": {
            "type": "number",
            "title": "Max Lat"
          },
          "min_lon": {
            "type": "number",
            "title": "Min Lon"
          },
          "max_lon": {
            "type": "number",
            "title": "Max Lon"
          },
          "resolved_category_keys": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Resolved Category Keys"
          },
          "business_score": {
            "items": {
              "items": {
                "anyOf": [
                  {
                    "type": "number"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "type": "array"
            },
            "type": "array",
            "title": "Business Score",
            "description": "Row index ~ south→north, column ~ west→east; null = outside training hull (skipped)."
          },
          "business_score_ml": {
            "items": {
              "items": {
                "anyOf": [
                  {
                    "type": "number"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "type": "array"
            },
            "type": "array",
            "title": "Business Score Ml"
          },
          "survival_probability": {
            "items": {
              "items": {
                "anyOf": [
                  {
                    "type": "number"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "type": "array"
            },
            "type": "array",
            "title": "Survival Probability",
            "description": "Survival head probability 0–1 per cell; null when cell skipped."
          },
          "predicted_stars": {
            "items": {
              "items": {
                "anyOf": [
                  {
                    "type": "number"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "type": "array"
            },
            "type": "array",
            "title": "Predicted Stars",
            "description": "Rating regressor: predicted stars (~0–5) per cell; null when cell skipped."
