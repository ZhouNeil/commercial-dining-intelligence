          "price_per_person": {
            "anyOf": [
              {
                "type": "number",
                "minimum": 0.0
              },
              {
                "type": "null"
              }
            ],
            "title": "Price Per Person",
            "description": "USD-ish per person; mapped to 1–4 if price_level not set."
          }
